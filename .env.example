# ============================================
# ASKID - Environment Variables
# ============================================
# Copy this file to .env and fill in the values

# ---------- General ----------
APP_NAME=ASKID
ENVIRONMENT=development
DEBUG=true
SECRET_KEY=your-secret-key-min-32-chars-change-in-production

# ---------- Database ----------
DATABASE_URL=postgresql+asyncpg://askid:askid_password@db:5432/askid
DATABASE_URL_SYNC=postgresql://askid:askid_password@db:5432/askid
POSTGRES_USER=askid
POSTGRES_PASSWORD=askid_password
POSTGRES_DB=askid

# ---------- Redis (session/cache) ----------
REDIS_URL=redis://redis:6379/0

# ---------- JWT ----------
JWT_SECRET_KEY=your-jwt-secret-key-min-32-chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ---------- LLM (OpenAI-compatible) ----------
# Option A - Google Gemini (free): get key at https://aistudio.google.com/apikey
# OPENAI_API_KEY=your-gemini-api-key
# OPENAI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
# OPENAI_CHAT_MODEL=gemini-2.0-flash
# OPENAI_EMBEDDING_MODEL=text-embedding-004
#
# Option B - OpenAI (paid): leave OPENAI_BASE_URL empty
# OPENAI_API_KEY=sk-your-openai-api-key
# OPENAI_BASE_URL=
# OPENAI_CHAT_MODEL=gpt-4o
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_API_KEY=your-api-key
OPENAI_BASE_URL=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4o
OPENAI_EMBEDDING_DIMENSIONS=1536

# ---------- S3 Storage ----------
S3_ENDPOINT_URL=http://minio:9000
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET_NAME=askid-documents
S3_REGION=us-east-1

# ---------- Frontend ----------
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_NAME=ASKID
NEXTAUTH_SECRET=your-nextauth-secret
NEXTAUTH_URL=http://localhost:3000

# ---------- CORS ----------
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ---------- Rate Limiting ----------
RATE_LIMIT_PER_MINUTE=60

# ---------- Encryption ----------
ENCRYPTION_KEY=your-32-byte-encryption-key-here
